# AFFiNE revision: stable, beta, or canary
AFFINE_REVISION=stable

# Port AFFiNE is exposed on
PORT=3010

# Persistent storage locations (uses your home dir by default)
DB_DATA_LOCATION=~/.affine/self-host/postgres/pgdata
UPLOAD_LOCATION=~/.affine/self-host/storage
CONFIG_LOCATION=~/.affine/self-host/config

# Database credentials — change DB_PASSWORD before first start
DB_USERNAME=affine
DB_PASSWORD=TheBodie21
DB_DATABASE=affine
